APP_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
SHEPHERD_PORT=5050
DB_NAME=shepherd_db
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=shepherd_user
DB_PASSWORD=shepherd_password
POSTGRES_PASSWORD=postgres
PGADMIN_DEFAULT_EMAIL=email@example.com
PGADMIN_DEFAULT_PASSWORD=password
DB_URL=postgres://shepherd_user:shepherd_password@localhost:5432/shepherd_db?sslmode=disable
CLIENT_ID=
CLIENT_SECRET=
CLIENT_CALLBACK_URL=
JWT_SECRET=your-secret-key-in-env-file

# GOOSE related environment variables
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://shepherd_user:shepherd_password@localhost:5432/shepherd_db?sslmode=disable
GOOSE_MIGRATION_DIR=./migrations